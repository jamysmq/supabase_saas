# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=

# n8n management API, used only from local/admin scripts when needed
N8N_BASE_URL=
N8N_API_KEY=

# WhatsApp Cloud API official Meta provider
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_GRAPH_VERSION=v23.0
WHATSAPP_PUBLIC_PHONE_E164=

# Internal app endpoint used by n8n to send WhatsApp messages
WHATSAPP_INTERNAL_SEND_TOKEN=

# Meta webhook verification and signature validation
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Optional forward from the app webhook receiver to the n8n inbound workflow
WHATSAPP_INBOUND_N8N_WEBHOOK_URL=
WHATSAPP_INBOUND_N8N_TOKEN=
